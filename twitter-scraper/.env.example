# Copy to .env and fill in. One line per burner account.
# Format: ACCOUNT_<N>=username|email|password|proxy_url
# proxy_url is optional (leave empty after the last pipe if none).
#
# Examples:
#   ACCOUNT_1=burner_alice|alice@mail.com|s3cret|http://user:pass@proxy.example:8000
#   ACCOUNT_2=burner_bob|bob@mail.com|pw|
#
# Each account also gets a cookie file at cookies/<username>.json after
# setup_accounts.py runs. Keep .env and cookies/ out of git.

ACCOUNT_1=
ACCOUNT_2=
ACCOUNT_3=
